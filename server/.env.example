# Server Environment Configuration Example
# Copy this to .env and fill in your actual values

# MongoDB URI (e.g., mongodb+srv://...)
MONGODB_URI=

# Secret key for JWT signing
JWT_SECRET=

# Cloudinary Credentials (Get these from your dashboard)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Server Port
PORT=5000

# Razorpay Credentials
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Email configuration
EMAIL_USER=connect2rachit882@gmail.com
EMAIL_PASS=
